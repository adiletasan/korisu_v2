# ============================================================
# KORISU — Environment Variables
# Скопируй этот файл в .env и заполни
# JWT ключи НЕ нужны в .env — они читаются из private.pem и public.pem
# ============================================================

# Google OAuth (необязательно для старта)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (необязательно — ссылки верификации будут в логах Docker)
SENDGRID_API_KEY=

# LiveKit — получи на cloud.livekit.io (бесплатно)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SECRET_ENCRYPTION_KEY=korisu-livekit-key-32-chars!!!!!
